{
  "name": "@keyward/codegen",
  "version": "0.0.1",
  "description": "CLI to generate type-safe storage key accessors from keyward.keys.json",
  "license": "MIT",
  "type": "module",
  "bin": {
    "keyward-codegen": "dist/cli.js"
  },
  "main": "dist/index.js",
