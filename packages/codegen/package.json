    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@keyward/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
